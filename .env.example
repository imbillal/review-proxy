PORT=8080
PROXY_DOMAIN=reviewproxy.app
APP_ORIGIN=http://localhost:3000
DATABASE_URL=
UPSTREAM_TIMEOUT_MS=20000
MAX_HTML_BYTES=15000000

# Public-facing scheme/port for same-origin link rewriting. Production terminates
# TLS upstream, so leave unset (defaults: https, no port). Local dev: http + 8080.
# PUBLIC_SCHEME=http
# PUBLIC_PORT=8080
